# CLIProxyAPI Docker Environment Configuration
# 复制自 .env.example，根据需要修改

# ------------------------------------------------------------------------------
# Docker 构建参数
# ------------------------------------------------------------------------------
VERSION=v1.0.0
COMMIT=local
BUILD_DATE=2026-05-09

# Docker 镜像名称
CLI_PROXY_IMAGE=cli-proxy-api:latest

# ------------------------------------------------------------------------------
# 卷挂载路径（Windows 路径示例）
# ------------------------------------------------------------------------------
# 配置文件路径（绝对路径或相对路径）
CLI_PROXY_CONFIG_PATH=./config.yaml

# 认证文件目录（存放 Kiro token、注册文件等）
CLI_PROXY_AUTH_PATH=./auths

# 日志目录
CLI_PROXY_LOG_PATH=./logs

# ------------------------------------------------------------------------------
# 运行时环境变量
# ------------------------------------------------------------------------------
# 部署模式（可选）
DEPLOY=production

# 时区设置（已在 Dockerfile 中设置为 Asia/Shanghai）
TZ=Asia/Shanghai

# ------------------------------------------------------------------------------
# Management Web UI（如果需要修改密码）
# ------------------------------------------------------------------------------
MANAGEMENT_PASSWORD=abcd.1234

# ------------------------------------------------------------------------------
# 可选：远程存储配置（默认使用本地文件存储，无需配置）
# ------------------------------------------------------------------------------
# Postgres Token Store（已启用）
POSTGRES_USER=cliproxy
POSTGRES_PASSWORD=cliproxy_password
POSTGRES_DB=cliproxy
POSTGRES_PORT=5432

# Git-Backed Config Store
# GITSTORE_GIT_URL=https://github.com/your-org/cli-proxy-config.git
# GITSTORE_GIT_USERNAME=git-user
# GITSTORE_GIT_TOKEN=ghp_your_personal_access_token
# GITSTORE_LOCAL_PATH=/data/cliproxy/gitstore

# Object Store Token Store
# OBJECTSTORE_ENDPOINT=https://s3.your-cloud.example.com
# OBJECTSTORE_BUCKET=cli-proxy-config
# OBJECTSTORE_ACCESS_KEY=your_access_key
# OBJECTSTORE_SECRET_KEY=your_secret_key
# OBJECTSTORE_LOCAL_PATH=/data/cliproxy/objectstore
